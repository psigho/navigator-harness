        <mxCell id="note" value="Context = STEER the brain (instant, reversible).&#10;Training = CHANGE the brain (slow, permanent).&#10;Navigator is the steering kind." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0e1117;strokeColor=#e7c14a;fontColor=#aab6c6;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="360" y="320" width="450" height="70" as="geometry" /></mxCell>
