<mxfile host="app.diagrams.net" type="device">
  <diagram name="Navigator — Context vs Prompt" id="nav-ctx-1">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="560" math="0" shadow="0" background="#0a0c10">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Preloaded context changes how it thinks — your prompt rides on top" style="text;html=1;fontColor=#3ad6c4;fontSize=15;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="700" height="28" as="geometry" /></mxCell>
        <mxCell id="lbl1" value="PRELOADED CONTEXT  ·  loaded BEFORE you type" style="text;html=1;fontColor=#6c7a8c;fontSize=11;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="66" width="320" height="20" as="geometry" /></mxCell>
        <mxCell id="persona" value="Persona / System file&#10;role · voice · rules · knowledge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141922;strokeColor=#3ad6c4;fontColor=#e8eef6;" vertex="1" parent="1"><mxGeometry x="40" y="92" width="230" height="58" as="geometry" /></mxCell>
        <mxCell id="skills" value="Loaded skills + maps&#10;domain knowledge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141922;strokeColor=#28313f;fontColor=#e8eef6;" vertex="1" parent="1"><mxGeometry x="40" y="162" width="230" height="48" as="geometry" /></mxCell>
        <mxCell id="history" value="Conversation history" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141922;strokeColor=#28313f;fontColor=#e8eef6;" vertex="1" parent="1"><mxGeometry x="40" y="222" width="230" height="40" as="geometry" /></mxCell>
        <mxCell id="prompt" value="YOUR PROMPT&#10;the request, on top" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1c6e66;strokeColor=#3ad6c4;fontColor=#e8eef6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="274" width="230" height="48" as="geometry" /></mxCell>
        <mxCell id="ctx" value="CONTEXT WINDOW&#10;the model's working memory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0e1117;strokeColor=#5aa9f0;fontColor=#e8eef6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="360" y="150" width="200" height="140" as="geometry" /></mxCell>
        <mxCell id="model" value="MODEL&#10;the brain — weights UNCHANGED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141922;strokeColor=#9b8cf0;fontColor=#e8eef6;" vertex="1" parent="1"><mxGeometry x="620" y="150" width="190" height="58" as="geometry" /></mxCell>
